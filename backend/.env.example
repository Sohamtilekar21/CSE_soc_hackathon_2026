# Supabase project settings (Project Settings > API)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Project Settings > API > JWT Settings > JWT Secret
SUPABASE_JWT_SECRET=your-jwt-secret

# Storage bucket used for uploaded images
SUPABASE_STORAGE_BUCKET=images

# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000

# Anthropic API key (console.anthropic.com) - used for clothing
# classification and outfit matching/building
ANTHROPIC_API_KEY=your-anthropic-api-key
